    if ( ! $contact_id ) {
        error_log( 'Impossible de récupérer l\'ID du contact CiviCRM : ' . wp_remote_retrieve_body( $reponse_contact ) );
        return;
    }

    // --- 2. Ajouter l'email au contact (si pas déjà présent) ---
    $params_email = array(
        'values' => array(
            'contact_id' => $contact_id,
            'email'      => $courriel,
            'is_primary' => true,
        ),
        'match' => array( 'contact_id', 'email' ),
    );

    wp_remote_post( $civicrm_domaine . '/civicrm/ajax/api4/Email/create', array(
        'method'  => 'POST',
        'timeout' => 15,
        'headers' => array(
            'X-Civi-Auth' => 'Bearer ' . $api_key,
        ),
        'body'    => array(
            'params' => wp_json_encode( $params_email ),
        ),
    ) );

    // --- 3. Ajouter le contact au groupe Infolettre ---
    $params_groupe = array(
        'values' => array(
            'contact_id' => $contact_id,
            'group_id'   => $id_groupe_infolettre,
            'status'     => 'Added',
        ),
        'match' => array( 'contact_id', 'group_id' ),
    );

    $reponse_groupe = wp_remote_post( $civicrm_domaine . '/civicrm/ajax/api4/GroupContact/create', array(
        'method'  => 'POST',
        'timeout' => 15,
        'headers' => array(
            'X-Civi-Auth' => 'Bearer ' . $api_key,
        ),
        'body'    => array(
            'params' => wp_json_encode( $params_groupe ),
        ),
    ) );

    if ( is_wp_error( $reponse_groupe ) ) {
        error_log( 'Erreur ajout au groupe CiviCRM : ' . $reponse_groupe->get_error_message() );
    } else {
        $code = wp_remote_retrieve_response_code( $reponse_groupe );
        if ( $code !== 200 ) {
            error_log( 'CiviCRM (groupe) a répondu avec le code ' . $code . ' : ' . wp_remote_retrieve_body( $reponse_groupe ) );
        }
    }
}
