    $parties_nom = explode( ' ', $nom, 2 );
    $prenom      = $parties_nom[0] ?? '';
    $nom_famille = $parties_nom[1] ?? '';

    // --- 1. Créer ou mettre à jour le contact (par courriel, anti-doublon) ---
    $params_contact = array(
        'records' => array(
            array(
                'first_name'   => $prenom,
                'last_name'    => $nom_famille,
                'contact_type' => 'Individual',
                'custom_1'     => $etablissement, // <-- à confirmer/ajuster selon ta vérification
                'email_primary.email' => $courriel,
            ),
        ),
        'match' => array( 'email' ),
    );

    $reponse_contact = wp_remote_post( $civicrm_domaine . '/civicrm/ajax/api4/Contact/save', array(
